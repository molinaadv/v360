# =====================================================================
# V360 — SECRETS  (cole isto em Streamlit Cloud → Settings → Secrets)
# NÃO comitar este arquivo com senhas reais no GitHub.
# =====================================================================
SUPABASE_URL = "https://SEU-PROJETO.supabase.co"
SUPABASE_KEY = "sua-chave-anon-ou-service"

# ---- Captação / Clientes (menu "Captação") ----
# A página Captação lê a tabela `captacao_leads`. Se o sistema V360 Clientes
# estiver no MESMO projeto Supabase acima, NÃO precisa configurar nada aqui.
# Se estiver em OUTRO projeto Supabase, descomente e preencha:
# CAPTACAO_SUPABASE_URL = "https://PROJETO-CLIENTES.supabase.co"
# CAPTACAO_SUPABASE_KEY = "chave-anon-do-projeto-clientes"

# ---- Usuários (login por e-mail + senha) ----
# unidades = "*"  -> vê TODAS as unidades (master)
# unidades = ["ATRIUM","COMPENSA"]  -> vê só essas

[usuarios.alexandre]
email    = "alexandre.brito@molinaadvogado.adv.br"
senha    = "P@ssw0rd"
nome     = "Alexandre (Master)"
role     = "master"
unidades = "*"

# Exemplo de acesso restrito (descomente e ajuste as unidades do Rodrigo):
